DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_ENV=dev

# Dev uses SQLite by default (DB_NAME optional):
# DB_NAME=db.sqlite3

# For production set DJANGO_ENV=prod and configure PostgreSQL:
# DB_NAME=deeppos
# DB_USER=pos_user
# DB_PASSWORD=pos_password
# DB_HOST=127.0.0.1
# DB_PORT=5432
